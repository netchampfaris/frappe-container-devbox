#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/.frappe-devbox.env"

IMAGE_NAME="${FRAPPE_IMAGE_NAME:-ghcr.io/netchampfaris/frappe-devbox:v16}"
MACHINE_NAME="${FRAPPE_MACHINE_NAME:-frappe-v16}"
BENCH_NAME="${FRAPPE_BENCH_NAME:-frappe-bench}"
CPUS="${FRAPPE_CPUS:-8}"
MEMORY="${FRAPPE_MEMORY:-16G}"
CONTAINER_PKG_URL="${CONTAINER_PKG_URL:-https://github.com/apple/container/releases/download/1.0.0/container-1.0.0-installer-signed.pkg}"

machine_exists() {
  container machine list --format json | grep -q "\"$MACHINE_NAME\""
}

if [[ "$(uname -m)" != "arm64" ]]; then
  echo "Apple container requires an Apple Silicon Mac." >&2
  exit 1
fi

MACOS_VERSION="$(sw_vers -productVersion)"
MACOS_MAJOR="${MACOS_VERSION%%.*}"

case "$MACOS_MAJOR" in
  ''|*[!0-9]*)
    echo "Could not parse macOS version: $MACOS_VERSION" >&2
    exit 1
    ;;
esac

if [[ "$MACOS_MAJOR" -lt 26 && "${FRAPPE_ALLOW_UNSUPPORTED_MACOS:-}" != "1" ]]; then
  echo "macOS 26 is required for this setup. Current version: $MACOS_VERSION" >&2
  exit 1
fi

if ! command -v container >/dev/null 2>&1; then
  echo "Apple container CLI is missing. Installing it now."
  echo "This requires your macOS administrator password."

  TMPDIR_FOR_CONTAINER_INSTALL="$(mktemp -d)"
  CONTAINER_PKG="$TMPDIR_FOR_CONTAINER_INSTALL/container-installer.pkg"
  trap 'rm -rf "$TMPDIR_FOR_CONTAINER_INSTALL"' EXIT

  curl -fL "$CONTAINER_PKG_URL" -o "$CONTAINER_PKG"
  sudo installer -pkg "$CONTAINER_PKG" -target /
fi

container system start --enable-kernel-install

DEFAULT_BENCH_DIR="$HOME/$BENCH_NAME"
printf "Where should the %s directory live on your Mac? [%s] " "$BENCH_NAME" "$DEFAULT_BENCH_DIR"
read -r BENCH_DIR
BENCH_DIR="${BENCH_DIR:-$DEFAULT_BENCH_DIR}"

mkdir -p "$BENCH_DIR"
BENCH_DIR="$(cd "$BENCH_DIR" && pwd -P)"

case "$BENCH_DIR" in
  "$HOME"/*|"$HOME") ;;
  *)
    echo "The bench directory must live under your home directory because container machine mounts your home directory." >&2
    echo "Choose a path under: $HOME" >&2
    exit 1
    ;;
esac

if [[ "${FRAPPE_BUILD_LOCAL:-}" == "1" ]]; then
  container build -t "$IMAGE_NAME" "$SCRIPT_DIR"
else
  container image pull "$IMAGE_NAME"
fi

if [[ "${FRAPPE_RECREATE_MACHINE:-}" == "1" ]] && machine_exists; then
  if ! container machine delete "$MACHINE_NAME"; then
    if machine_exists; then
      echo "Failed to delete container machine '$MACHINE_NAME'." >&2
      echo "Try: container system stop && container system start && FRAPPE_RECREATE_MACHINE=1 ./setup" >&2
      exit 1
    fi
  fi
fi

if ! machine_exists; then
  container machine create \
    --name "$MACHINE_NAME" \
    --cpus "$CPUS" \
    --memory "$MEMORY" \
    --home-mount rw \
    --set-default \
    --no-boot \
    "$IMAGE_NAME"
else
  container machine set-default "$MACHINE_NAME"
fi

cat > "$CONFIG_FILE" <<EOF
FRAPPE_IMAGE_NAME="$IMAGE_NAME"
FRAPPE_MACHINE_NAME="$MACHINE_NAME"
FRAPPE_BENCH_NAME="$BENCH_NAME"
FRAPPE_BENCH_DIR="$BENCH_DIR"
EOF

cat <<MSG

Setup complete.

Bench directory on your Mac:
  $BENCH_DIR

Open it in your editor, then enter the devbox:
  ./frappe-shell

Inside the shell, use bench-cli:
  bench new $BENCH_NAME
  bench init
  bench new-site site1.localhost
  bench start

MSG
